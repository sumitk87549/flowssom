{
  "expo": {
    "name": "Flowssom",
    "slug": "flowssom",
    "scheme": "flowssom",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "plugins": ["expo-router", "expo-notifications", "expo-image-picker"],
    "android": {
      "package": "com.flowssom.app",
      "permissions": ["android.permission.MODIFY_AUDIO_SETTINGS", "android.permission.POST_NOTIFICATIONS"]
    },
    "ios": {
      "bundleIdentifier": "com.flowssom.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Choose your own peaceful wallpaper image."
      }
    },
    "extra": {
      "supabaseUrl": "",
      "supabaseAnonKey": ""
    }
  }
}
